{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "skillich Function Definition",
  "description": "Schema for _function.yaml files in the skillich taxonomy",
  "type": "object",
  "required": ["function"],
  "additionalProperties": false,
  "properties": {
    "function": {
      "type": "object",
      "required": ["id", "name", "description", "roles"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "roles": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "minItems": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
