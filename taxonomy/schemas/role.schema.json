{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "skillich Role Definition",
  "description": "Schema for role YAML files in the skillich taxonomy",
  "type": "object",
  "required": ["role"],
  "additionalProperties": false,
  "properties": {
    "role": {
      "type": "object",
      "required": ["id", "function", "name", "description", "ai_impact", "levels", "skills"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "function": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "also_known_as": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string", "minLength": 1 },
        "ai_impact": { "$ref": "#/$defs/role_ai_impact" },
        "levels": {
          "type": "array",
          "items": { "$ref": "#/$defs/level" },
          "minItems": 1
        },
        "skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/skill" },
          "minItems": 5,
          "maxItems": 20
        }
      }
    }
  },
  "$defs": {
    "role_ai_impact": {
      "type": "object",
      "required": ["level", "summary", "automating", "augmenting", "preserving"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "moderate", "moderate-high", "high", "very-high"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "automating": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "augmenting": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "preserving": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "last_reviewed": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}$",
          "description": "Year-month when this role's AI impact was last reviewed (e.g. 2025-09)"
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Confidence in ratings: low=expert estimate, medium=supported by research, high=empirically validated"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "level": {
      "type": "object",
      "required": ["id", "name", "years_experience", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "years_experience": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "skill": {
      "type": "object",
      "required": ["id", "name", "category", "description", "proficiency", "ai_impact"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["technical", "analytical", "leadership", "communication", "domain", "interpersonal", "clinical", "regulatory", "execution", "operational", "strategic", "professional"]
        },
        "description": { "type": "string", "minLength": 1 },
        "proficiency": {
          "type": "object",
          "minProperties": 3,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "ai_impact": {
          "type": "object",
          "required": ["rating", "detail"],
          "additionalProperties": false,
          "properties": {
            "rating": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "detail": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
